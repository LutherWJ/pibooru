{
  "name": "mybooru",
  "version": "0.5.26-beta",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun src/server/index.tsx",
    "build": "bun build src/client/index.ts --outdir public/dist --minify",
    "typecheck": "bun x tsc --noEmit",
    "test": "DATA_DIR=./data-test bun test src/server",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "bun run typecheck && bun run build && bun run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.14",
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
